-- 角色切换函数
local function switchCharacter(characterName, displayName)
    local args = { characterName, 0 }
    pcall(function()
        game:GetService("ReplicatedStorage"):WaitForChild("ForChangeCharacter"):FireServer(unpack(args))
    end)
    WindUI:Notify({
        Title = "角色切换",
        Content = "已切换到：" .. displayName,
        Duration = 3
    })
end

