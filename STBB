-- 使用 Rayfield UI 库
local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local player = game.Players.LocalPlayer

-- 创建窗口
local Window = Rayfield:CreateWindow({
    Name = "STBB",
    LoadingTitle = "STBB ",
    LoadingSubtitle = "by STBB",
    Theme = "Dark",
    Configuration = {
        CheckForUpdates = false,
    }
})

-- 角色切换标签页
local characterTab = Window:CreateTab("角色切换")
characterTab:CreateSection("角色控制")

-- 重置人物
characterTab:CreateButton({
    Name = "重置人物",
    Callback = function()
        if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            player.Character.HumanoidRootPart.CFrame = CFrame.new(0, -975, 0)
            Rayfield:Notify({
                Title = "重置人物",
                Content = "已将角色传送到虚空",
                Duration = 3
            })
        else
            Rayfield:Notify({
                Title = "错误",
                Content = "无法找到角色或HumanoidRootPart",
                Duration = 3
            })
        end
    end
})

